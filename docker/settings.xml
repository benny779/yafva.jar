<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0
                              https://maven.apache.org/xsd/settings-1.0.0.xsd">
  <servers>
    <!--
      Auth for the Outburn-IL fork of org.hl7.fhir.core, published to
      GitHub Packages. GITHUB_ACTOR / GITHUB_TOKEN are injected via
      Docker BuildKit secrets (see docker/Dockerfile). Locally, export
      both env vars before `docker build` (token needs read:packages).
    -->
    <server>
      <id>github-yafva</id>
      <username>${env.GITHUB_ACTOR}</username>
      <password>${env.GITHUB_TOKEN}</password>
    </server>
  </servers>
</settings>
